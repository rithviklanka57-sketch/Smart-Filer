# Smart Drive Filer — Backend Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings (Voyage AI) ────────────────────────────────────────────────────
EMBEDDING_API_KEY=pa-...
EMBEDDING_MODEL=voyage-3
EMBEDDING_BASE_URL=https://api.voyageai.com/v1

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://smartfiler:smartfiler@localhost:5432/smartfiler
DATABASE_URL_SYNC=postgresql://smartfiler:smartfiler@localhost:5432/smartfiler

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
